EXPO_PUBLIC_APP_URL=https://app.luka.com.br

# Como configurar no Vercel:
# 1. Acesse vercel.com e importe o repositório GitHub do Luka
# 2. Em Settings → Environment Variables, adicione as 3 variáveis acima
# 3. Em Settings → General → Root Directory, deixe vazio (raiz do repo)
# 4. O build command já está no vercel.json: npx expo export --platform web
# 5. Output directory: dist
#
# Domínio personalizado:
# Settings → Domains → adicione app.luka.com.br
# Aponte o DNS: CNAME app → cname.vercel-dns.com
