{
  "name": "luka-psi",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --testPathPatterns='src/__tests__' --forceExit",
    "test:coverage": "jest --testPathPatterns='src/__tests__' --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react"
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@hookform/resolvers": "^3.3.4",
    "@react-native-community/datetimepicker": "^7.6.2",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "date-fns": "^3.2.0",
    "expo": "~52.0.0",
    "expo-image": "~2.0.0",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "nativewind": "^4.0.36",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.49.0",
    "react-native": "0.76.7",
    "react-native-web": "~0.19.13",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.12",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.0"
  },
  "private": true,
  "overrides": {
    "ajv": "^8.12.0"
  }
}
